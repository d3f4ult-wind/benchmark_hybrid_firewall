# =============================================================================
# suricata_slowloris.rules
# Phát hiện tấn công Slow Loris vào nginx port 80
# =============================================================================
#
# GIẢI THÍCH THIẾT KẾ RULE:
#
# Slow Loris hoạt động bằng cách mở nhiều TCP connection đến port 80 và
# gửi HTTP header RẤT CHẬM — mỗi vài giây chỉ gửi thêm một dòng header nhỏ,
# không bao giờ kết thúc request (không gửi \r\n\r\n). Mục tiêu là giữ
# connection mở mãi để chiếm hết worker_connections của nginx.
#
# Vì mỗi packet đơn lẻ trông hoàn toàn hợp lệ về mặt TCP/IP, XDP không thể
# phân biệt được đây là tấn công. Suricata nhìn được ở tầng L7 (HTTP) và
# có thể theo dõi pattern theo thời gian — đây chính là giá trị của tầng này.
#
# CHIẾN LƯỢC PHÁT HIỆN: Dùng threshold trên số connection mới từ cùng một IP.
# Slow Loris cần mở RẤT NHIỀU connection liên tục để chiếm pool — đây là
# dấu hiệu bất thường so với user bình thường (vài connection tối đa).
#
# Rule 1: Phát hiện SYN nhiều (connection mới liên tục từ một IP)
# Đây là dấu hiệu rõ nhất — Slow Loris terus mở connection mới khi cũ bị đóng.
# threshold: 20 connection mới trong 10 giây từ cùng một IP → alert.
# Con số này đủ nhạy để bắt Slow Loris (--socket-count 100+) mà không false
# positive với user bình thường (vài connection trong nhiều giây).
alert tcp any any -> $HOME_NET 80 (
    msg:"SLOWLORIS Excessive new connections to HTTP port";
    flags:S;
    flow:to_server;
    threshold: type threshold, track by_src, count 20, seconds 10;
    sid:9000001;
    rev:1;
    classtype:attempted-dos;
    metadata:affected_product nginx, attack_target Web_Server;
)

# Rule 2: Phát hiện HTTP header không hoàn chỉnh (partial header pattern)
# Slow Loris gửi data rất ít mỗi lần — mỗi packet payload thường chỉ vài byte.
# Rule này bắt pattern: có HTTP request bắt đầu (GET/POST) nhưng payload cực nhỏ.
# dsize: kích thước payload của packet (không tính TCP header).
# Kết hợp threshold để tránh false positive với request nhỏ thực sự hợp lệ.
alert tcp any any -> $HOME_NET 80 (
    msg:"SLOWLORIS Partial HTTP header detected - possible slow attack";
    flow:established,to_server;
    content:"GET";
    dsize:<50;
    threshold: type threshold, track by_src, count 10, seconds 30;
    sid:9000002;
    rev:1;
    classtype:attempted-dos;
    metadata:affected_product nginx, attack_target Web_Server;
)

# Rule 3: Backup rule — nhiều established connection từ một IP không gửi data
# Đây là safety net: nếu rule 1 và 2 miss, rule này bắt pattern lâu dài.
# Nếu cùng một IP có >30 connection established đến port 80 trong 60 giây
# mà không hoàn thành request, đây gần chắc là Slow Loris.
alert tcp any any -> $HOME_NET 80 (
    msg:"SLOWLORIS Sustained connection flood to HTTP - likely slow attack";
    flags:S;
    flow:to_server;
    threshold: type threshold, track by_src, count 30, seconds 60;
    sid:9000003;
    rev:1;
    classtype:attempted-dos;
    metadata:affected_product nginx, attack_target Web_Server;
)
